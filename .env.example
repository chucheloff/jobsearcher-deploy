# jobsearcher-deploy — environment template.
# Copy to `.env` and fill in everything marked CHANGEME.
# `.env` is gitignored; never commit secrets.

# ─── openclaw gateway ─────────────────────────────────────────────────────────
# Where openclaw persists config and workspace skills/MEMORY.md/etc.
OPENCLAW_CONFIG_DIR=${HOME}/.openclaw
OPENCLAW_WORKSPACE_DIR=${HOME}/.openclaw/workspace

# Gateway HTTP and WS bridge ports (host-published).
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_BRIDGE_PORT=18790
OPENCLAW_GATEWAY_BIND=lan

# Auth token openclaw-cli uses to talk to the gateway. Generate a fresh value
# with `openssl rand -hex 32`. Required.
OPENCLAW_GATEWAY_TOKEN=CHANGEME-openclaw-gateway-token

# Image pin. `openclaw:local` works after a `docker build` of the openclaw repo.
OPENCLAW_IMAGE=openclaw:local

# Skip bonjour discovery (we don't use any of openclaw's channel plugins here).
OPENCLAW_DISABLE_BONJOUR=1

OPENCLAW_TZ=UTC

# `getent group docker | cut -d: -f3` on the host. Lets the cli container talk
# to /var/run/docker.sock if you need it (currently optional).
DOCKER_GID=999

# ─── jobmcp (mock job listings, FastAPI + Valkey) ─────────────────────────────
JOBMCP_HOST=0.0.0.0
JOBMCP_PORT=8000
JOBMCP_MCP_PATH=/mcp
JOBMCP_STATELESS_HTTP=true
JOBMCP_VALKEY_URL=redis://valkey:6379/0
JOBMCP_VALKEY_PREFIX=jobmcp
JOBMCP_SEED_ON_STARTUP=true

# ─── slack-mcp ────────────────────────────────────────────────────────────────
# Slack bot token (xoxb-...) and app token (xapp-...). Both required.
# https://api.slack.com/apps → your bot → "OAuth & Permissions" / "Basic info".
SLACK_MCP_XOXB_TOKEN=xoxb-CHANGEME
SLACK_MCP_XAPP_TOKEN=xapp-CHANGEME

SLACK_MCP_PORT=13080

# Slack channel the job-search skill posts heads-ups into. Right-click channel
# in Slack → "Copy link"; the trailing `/Cxxxxx` is the id.
SLACK_DEFAULT_CHANNEL_ID=CHANGEME-slack-channel-id
SLACK_DEFAULT_CHANNEL_NAME=job-search
SLACK_MCP_ADD_MESSAGE_TOOL=true

# ─── company-mcp ──────────────────────────────────────────────────────────────
COMPANYMCP_PORT=8080

# Tavily for `recent_news`. Free tier is fine.
# https://tavily.com → API keys.
TAVILY_API_KEY=tvly-CHANGEME

# OpenRouter (used by company-mcp's company_profile extractor + synthesizer,
# AND by openclaw's agent for the heavy/mid/cheap aliases).
OPENROUTER_API_KEY=sk-or-v1-CHANGEME

# Active models for company-mcp. The `switch-openrouter-tier.sh` script flips
# these between free and paid presets.
OPENROUTER_EXTRACTION_MODEL=anthropic/claude-3.5-haiku
OPENROUTER_QUALITY_MODEL=anthropic/claude-3-opus

# Paid | free. Mostly informational — the switch script writes this when it
# rewrites .env so future runs know which tier was last selected.
OPENROUTER_TIER=paid

# ─── gmail-mcp (Resend backend, with optional SMTP fallback) ──────────────────
# The Resend free tier only delivers to the account owner — see README.
RESEND_API_KEY=re_CHANGEME
RESEND_FROM=YourBotName <onboarding@resend.dev>
MAIL_DEFAULT_TO=you@example.com
MAILER_BACKEND=resend

# Optional SMTP fallback (Gmail app password). Leave blank if you only want
# Resend; keep these set if you want the gmail-mcp to be able to fall over.
GMAIL_USER=you@example.com
GMAIL_APP_PASSWORD=CHANGEME-app-password
GMAIL_FROM_NAME=YourBotName
GMAIL_DEFAULT_TO=you@example.com
GMAILMCP_PORT=8090


# ─── realjobmcp (live job-search MCP backed by tavilysearch) ──────────────────
# Live counterpart to jobmcp. The job-search skill picks one or the other based
# on the `backend` arg (default mock). TAVILY_API_KEY above is reused.
REALJOBMCP_PORT=8000
REALJOBMCP_HOST_PORT=8001
REALJOBMCP_MCP_PATH=/mcp

# Comma-separated providers to enable. `tavily` needs TAVILY_API_KEY (already
# set above for company-mcp); `remotive` needs no key. The other providers
# (adzuna, greenhouse, lever, ashby) require their own keys/board tokens
# configured below — leave them blank to skip.
REALJOBMCP_ENABLED_PROVIDERS=tavily,remotive

# Optional comma-separated domain allowlist for Tavily (defaults to upstream
# tavilysearch list when blank). Tighten to your preferred boards if desired.
REALJOBMCP_TAVILY_DOMAINS=

REALJOBMCP_REQUEST_TIMEOUT_SECONDS=20
REALJOBMCP_CACHE_ENABLED=true
REALJOBMCP_CACHE_TTL_SECONDS=900

# Adzuna (broad aggregator). Free tier: https://developer.adzuna.com/. Optional.
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
ADZUNA_COUNTRY=us

# Public ATS boards. Comma-separated tokens/sites. All optional.
GREENHOUSE_BOARD_TOKENS=
LEVER_SITES=
ASHBY_BOARD_NAMES=

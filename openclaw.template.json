{
  "gateway": {
    "mode": "local",
    "bind": "lan",
    "controlUi": {
      "allowedOrigins": [
        "http://localhost:18789",
        "http://127.0.0.1:18789"
      ]
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "openrouter/anthropic/claude-haiku-4.5",
        "fallbacks": [
          "openrouter/anthropic/claude-sonnet-4.6"
        ]
      },
      "models": {
        "openrouter/anthropic/claude-haiku-4.5": {
          "alias": "cheap"
        },
        "openrouter/anthropic/claude-sonnet-4.6": {
          "alias": "mid"
        },
        "openrouter/anthropic/claude-opus-4.7": {
          "alias": "heavy"
        }
      },
      "params": {
        "max_tokens": 4096
      }
    }
  },
  "mcp": {
    "servers": {
      "jobmcp": {
        "url": "http://jobmcp:8000/mcp",
        "transport": "streamable-http"
      },
      "slack": {
        "url": "http://slack-mcp:13080/mcp",
        "transport": "streamable-http"
      },
      "company": {
        "url": "http://company-mcp:8080/mcp",
        "transport": "streamable-http"
      },
      "gmail": {
        "url": "http://gmail-mcp:8090/mcp",
        "transport": "streamable-http"
      }
    }
  },
